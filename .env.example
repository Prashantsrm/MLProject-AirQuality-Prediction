# Environment Variables Template for Air Quality Prediction System
# Copy this file to .env and fill in your actual values
# DO NOT commit .env file to version control

# ============================================================================
# REQUIRED: Data Source Credentials
# ============================================================================

# IQAir API Key
# Obtain from: https://waqi.info/api/
# Free tier: 10,000 calls/month
IQAIR_API_KEY=your_iqair_api_key_here

# CPCB Dataset API Credentials
# Obtain from: https://www.kaggle.com/settings/account
# 1. Create account and go to Account Settings → API
# 2. Click "Create New API Token"
# 3. This downloads credentials.json
CPCB_USERNAME=your_cpcb_username
CPCB_KEY=your_cpcb_api_key

# ============================================================================
# OPTIONAL: System Configuration
# ============================================================================

# System Environment (development, staging, production)
AQI_SYSTEM_ENVIRONMENT=development

# Logging Level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
AQI_SYSTEM_LOG_LEVEL=INFO

# Random Seed for Reproducibility
AQI_SYSTEM_RANDOM_SEED=42

# ============================================================================
# OPTIONAL: Storage Paths
# ============================================================================

# Bronze Layer (Raw Data)
AQI_STORAGE_BRONZE_PATH=data/bronze

# Silver Layer (Cleaned Data)
AQI_STORAGE_SILVER_PATH=data/silver

# Gold Layer (Feature-Engineered Data)
AQI_STORAGE_GOLD_PATH=data/gold

# Models Storage
AQI_STORAGE_MODELS_PATH=data/models

# Logs Storage
AQI_STORAGE_LOGS_PATH=logs

# ============================================================================
# OPTIONAL: Streaming Configuration
# ============================================================================

# Kafka Bootstrap Servers (comma-separated)
AQI_STREAMING_KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Kafka Topic for AQI Events
AQI_STREAMING_TOPIC=aqi-events

# Kafka Consumer Group
AQI_STREAMING_CONSUMER_GROUP=aqi-consumer

# Maximum Latency (milliseconds)
AQI_STREAMING_MAX_LATENCY_MS=1000

# ============================================================================
# OPTIONAL: Dashboard Configuration
# ============================================================================

# Dashboard Port
AQI_DASHBOARD_PORT=8501

# Dashboard Host
AQI_DASHBOARD_HOST=0.0.0.0

# Dashboard Refresh Interval (minutes)
AQI_DASHBOARD_REFRESH_INTERVAL_MINUTES=5

# ============================================================================
# OPTIONAL: Alert Configuration
# ============================================================================

# Alert Deduplication Window (hours)
AQI_ALERTS_DEDUP_WINDOW_HOURS=1

# Model-Based Alert Prediction Threshold (AQI)
AQI_ALERTS_PREDICTION_THRESHOLD=150

# ============================================================================
# OPTIONAL: ETL Configuration
# ============================================================================

# Batch Size for ETL Processing
AQI_ETL_BATCH_SIZE=1000

# Processing Interval (hours)
AQI_ETL_PROCESSING_INTERVAL_HOURS=1

# Maximum Retries for Failed Operations
AQI_ETL_MAX_RETRIES=3

# Retry Delay (seconds) - uses exponential backoff
AQI_ETL_RETRY_DELAY_SECONDS=30

# ============================================================================
# OPTIONAL: PySpark Configuration
# ============================================================================

# Spark Driver Memory
SPARK_DRIVER_MEMORY=4g

# Spark Executor Memory
SPARK_EXECUTOR_MEMORY=4g

# Spark Local IP
SPARK_LOCAL_IP=127.0.0.1

# ============================================================================
# OPTIONAL: Database Configuration (if using external database)
# ============================================================================

# Database URL (for alert storage, if using external DB)
# DATABASE_URL=postgresql://user:password@localhost:5432/aqi_db

# ============================================================================
# OPTIONAL: Monitoring Configuration
# ============================================================================

# Enable Monitoring Dashboard
ENABLE_MONITORING_DASHBOARD=true

# Monitoring Dashboard Port
MONITORING_DASHBOARD_PORT=8502

# ============================================================================
# NOTES
# ============================================================================
# 1. Keep this file secure - it contains sensitive credentials
# 2. Never commit .env to version control
# 3. Use strong, unique API keys
# 4. Rotate credentials regularly
# 5. For production, use a secrets management system (e.g., AWS Secrets Manager)
# 6. All values are optional except IQAIR_API_KEY and CPCB credentials
# 7. Environment variables override config.yaml values
